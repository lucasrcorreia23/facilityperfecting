# ── Front (browser) ───────────────────────────────────────────────
# Projeto Supabase do produto externo (NÃO é o backend da Perfecting).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ── Edge Functions (supabase secrets set ...) ─────────────────────
# Estes NÃO vão no .env.local do front — são secrets das Edge Functions.
# Definir com:  supabase secrets set PERFECTING_API_BASE=... etc.
#
# PERFECTING_API_BASE=https://api-hml.perfecting.app
# PERFECTING_SUPERADMIN_EMAIL=...
# PERFECTING_SUPERADMIN_PASSWORD=...
# SUPABASE_URL=...                # injetado automaticamente pelo runtime
# SUPABASE_SERVICE_ROLE_KEY=...   # injetado automaticamente pelo runtime
